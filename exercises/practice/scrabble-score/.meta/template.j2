{{ header }}
{% for idx, case in cases %}
@test '{{ case["description"] }}' {
    {% if idx == 0 %}# {% endif %}[[ $BATS_RUN_SKIPPED == "true" ]] || skip
    run gawk -f {{ solution }} <<< '{{ case["input"]["word"] }}'

    assert_success
    assert_output '{{ case["input"]["word"] | upper }},{{ case["expected"] }}'
}
{% endfor %}
@test 'bonus: blank tile counts as zero' {
    [[ $BATS_RUN_SKIPPED == "true" ]] || skip
    run gawk -f {{ solution }} <<< 'abcdefghijklmnop rstuvwxyz'

    assert_success
    assert_output 'ABCDEFGHIJKLMNOP RSTUVWXYZ,77'
}
